{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/_lib/dispatcher.py SessionStart",
            "timeout": 15,
            "statusMessage": "Loading session context (project detection, git info, framework detection)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/_lib/dispatcher.py PreToolUse",
            "timeout": 10,
            "statusMessage": "Checking command safety (security, secrets, git protection, Docker, K8s, IaC)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/_lib/dispatcher.py PostToolUse",
            "timeout": 15,
            "statusMessage": "Analyzing output (errors, code quality, performance, testing, monitoring)"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/_lib/dispatcher.py UserPromptSubmit",
            "timeout": 10,
            "statusMessage": "Scanning prompt for secrets and injection"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/_lib/dispatcher.py Stop",
            "timeout": 10,
            "statusMessage": "Checking for auto-continue conditions"
          }
        ]
      }
    ]
  }
}
