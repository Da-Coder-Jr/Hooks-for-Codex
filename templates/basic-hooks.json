{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "shell",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"defer\"}}'",
            "timeout": 5,
            "statusMessage": "Checking command..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "# Add your post-tool-use hook here. Receives JSON on stdin with tool_name, tool_input, tool_output.",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "# Add your stop hook here. Exit 2 to force the agent to continue.",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
