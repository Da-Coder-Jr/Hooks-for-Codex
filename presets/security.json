{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/pre_tool_use_guard.py",
            "statusMessage": "Security: checking command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/user_prompt_filter.py",
            "statusMessage": "Security: scanning prompt"
          }
        ]
      }
    ]
  }
}
